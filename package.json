{
  "name": "hl7-tstd",
  "version": "1.0.0-dev.2",
  "description": "A simple lightweight package to create, parse & transform HL7 message.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "require": "./dist/index.cjs"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=10.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "tsup && node --test"
  },
  "keywords": [
    "hl7",
    "standard",
    "parse",
    "create",
    "transform",
    "format",
    "hl7-tstd"
  ],
  "author": "1nandagopal",
  "license": "Apache-2.0",
  "homepage": "https://github.com/1nandagopal/hl7-tstd#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1nandagopal/hl7-tstd.git"
  },
  "bugs": {
    "url": "https://github.com/1nandagopal/hl7-tstd/issues"
  },
  "sideEffects": false,
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.2"
  }
}
